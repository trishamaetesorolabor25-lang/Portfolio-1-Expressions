    "### Currency Converter"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 40,
   "id": "32404bff-8d01-4414-b637-a2903e29715f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Currency Converter \n"
     ]
    },
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter Philippine Peso Amount:  100\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Converted Currency Values\n",
      "United States Dollar: 1.6\n",
      "Japanese Yen: 256.0\n",
      "United Arab Emirates Dirham: 6.0\n",
      "South Korean Won: 2423.0\n",
      "Australian Dollar: 2.3\n",
      "Thailand Baht: 53.0\n"
     ]
    }
   ],
   "source": [
    "# Currency Converter \n",
    "# This program converts Philippine Pesos to different currencies\n",
    "# Exchange rates may be inaccurate because currency values can change over time\n",
    "\n",
    "# Display the title of the program\n",
    "print(\"Currency Converter \")\n",
    "\n",
    "# Ask the user to enter the amount in Philippine Peso\n",
    "peso_amount = input(\"Enter Philippine Peso Amount: \")\n",
    "\n",
    "# Convert the input into a decimal number\n",
    "peso_amount = float(peso_amount)\n",
    "\n",
    "# Convert Philippine Peso to different currencies\n",
    "\n",
    "# Convert PHP to United States Dollar\n",
    "usd = peso_amount * 0.016\n",
    "\n",
    "# Convert PHP to Japanese Yen\n",
    "yen = peso_amount * 2.56\n",
    "\n",
    "# Convert PHP to United Arab Emirates Dirham\n",
    "aed = peso_amount * 0.060\n",
    "\n",
    "# Convert PHP to South Korean Won\n",
    "won = peso_amount * 24.23\n",
    "\n",
    "# Convert PHP to Australian Dollar\n",
    "aus = peso_amount * 0.023\n",
    "\n",
    "# Convert PHP to Thailand Baht \n",
    "baht = peso_amount * 0.53\n",
    "\n",
    "# Display the converted amounts\n",
    "print(\"\\nConverted Currency Values\")\n",
    "print(\"United States Dollar:\", usd)\n",
    "print(\"Japanese Yen:\", yen)\n",
    "print(\"United Arab Emirates Dirham:\", aed)\n",
    "print(\"South Korean Won:\", won)\n",
    "print (\"Australian Dollar:\", aus)\n",
    "print (\"Thailand Baht:\", baht)"
   ]
