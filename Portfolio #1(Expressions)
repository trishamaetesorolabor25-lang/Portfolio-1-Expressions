    "### Discount Calculator "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 39,
   "id": "38e3f81b-5630-4760-b9d5-c7cdcf7a838b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Discount Calculator\n"
     ]
    },
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter original price: 100\n",
      "Enter discount percentage: 20\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Results\n",
      "Original Price: 100.0\n",
      "Discount Amount: 20.0\n",
      "Final Price: 80.0\n"
     ]
    }
   ],
   "source": [
    "# Discount Calculator \n",
    "# This Program calculates the final price after discount\n",
    "\n",
    "# Display Title\n",
    "print (\"Discount Calculator\")\n",
    "\n",
    "# Ask user to for original price\n",
    "price = input(\"Enter original price:\")\n",
    "\n",
    "# Ask user for discount percentage\n",
    "discount = input(\"Enter discount percentage:\")\n",
    "\n",
    "# Convert inputs to float\n",
    "price = float(price)\n",
    "discount =  float(discount)\n",
    "\n",
    "# Conver percentage to decimal\n",
    "discount_rate = discount / 100 \n",
    "\n",
    "# Compute discount amount (expression)\n",
    "discount_amount = price * discount_rate\n",
    "\n",
    "# Compute final price (expression)\n",
    "final_price = price - discount_amount\n",
    "\n",
    "# Display results\n",
    "print(\"\\nResults\")\n",
    "print(\"Original Price:\", price)\n",
    "print(\"Discount Amount:\", discount_amount)\n",
    "print(\"Final Price:\", final_price)\n"
   ]
